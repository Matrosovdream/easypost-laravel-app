APP_NAME=ShipDesk
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ───── Database (Postgres inside docker) ─────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=easypost
DB_USERNAME=easypost
DB_PASSWORD=secret

POSTGRES_PORT=5432

# ───── Session / cache / queue (Redis) ─────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ───── Mail ─────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@shipdesk.local"
MAIL_FROM_NAME="${APP_NAME}"

# EmailService driver: 'smtp' (Laravel Mail) | 'mailgun'
EMAIL_DRIVER=smtp

MAILGUN_SECRET=
MAILGUN_DOMAIN=
MAILGUN_ENDPOINT=https://api.mailgun.net/v3

POSTMARK_API_KEY=
RESEND_API_KEY=

# ───── AWS (S3) ─────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ───── Slack ─────
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=

# ───── EasyPost ─────
EASYPOST_API_KEY=
EASYPOST_TEST_API_KEY=
EASYPOST_WEBHOOK_SECRET=
EASYPOST_BASE_URL=https://api.easypost.com/v2
EASYPOST_TIMEOUT=30

# ───── Stripe (billing) ─────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ───── Frontend ─────
VITE_APP_NAME="${APP_NAME}"

# ───── Reverb (websockets) ─────
# Generate a fresh app id/key/secret per environment.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=

# Internal — used by PHP-FPM/Horizon to reach Reverb over the docker network.
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# Public — used by the browser (rendered into the dashboard blade <meta>).
# Browser connects to ws://localhost:${REVERB_PUBLIC_PORT} → docker maps it to reverb:8080.
REVERB_PUBLIC_HOST=localhost
REVERB_PUBLIC_PORT=9090
REVERB_PUBLIC_SCHEME=http

# ───── Sanctum (SPA cookie auth) ─────
SANCTUM_STATEFUL_DOMAINS=localhost:8080,localhost,127.0.0.1:8080,127.0.0.1

# ───── PIN login ─────
# 32+ byte random pepper — generate with: php -r "echo base64_encode(random_bytes(32));"
PIN_PEPPER=

# ───── Docker port overrides (optional) ─────
NGINX_PORT=8080
VITE_PORT=5173
REDIS_PORT=6379
ADMINER_PORT=9091
MEILISEARCH_PORT=7700
MEILISEARCH_KEY=masterKey
UID=1000
GID=1000
XDEBUG_ENABLED=false
